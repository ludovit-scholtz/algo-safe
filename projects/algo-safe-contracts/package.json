{
  "name": "algo-safe",
  "version": "1.1.0",
  "description": "Algo Safe smart contracts and client utilities",
  "homepage": "https://github.com/ludovit-scholtz/algo-safe#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ludovit-scholtz/algo-safe.git",
    "directory": "projects/algo-safe-contracts"
  },
  "bugs": {
    "url": "https://github.com/ludovit-scholtz/algo-safe/issues"
  },
  "keywords": [
    "algorand",
    "multisig",
    "smart-account",
    "safe",
    "smart-contract",
    "algokit",
    "puya-ts"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "algokit compile ts smart_contracts --output-source-map --out-dir artifacts && algokit generate client smart_contracts/artifacts --output {app_spec_dir}/{contract_name}Client.ts && pnpm run sync-versioned-client",
    "build:contracts": "pnpm build",
    "build-package": "pnpm run sync-versioned-client && tsup src/index.ts --format cjs,esm --clean --sourcemap --external @algorandfoundation/algokit-utils --external algosdk --external tslib && tsc -p tsconfig.package.json",
    "deploy": "ts-node-dev --transpile-only --watch .env -r dotenv/config smart_contracts/index.ts",
    "deploy:ci": "ts-node --transpile-only -r dotenv/config smart_contracts/index.ts",
    "lint": "eslint smart_contracts",
    "lint:fix": "eslint smart_contracts --fix",
    "audit": "pnpm audit --audit-level high",
    "format": "prettier --write .",
    "publish-package": "npm publish",
    "test": "vitest run --coverage",
    "test:e2e": "vitest run smart_contracts/**/*.e2e.spec.ts",
    "test:watch": "vitest watch",
    "check-types": "tsc --noEmit",
    "compute-bytecode-hashes": "ts-node scripts/compute-bytecode-hashes.ts",
    "sync-versioned-client": "ts-node scripts/sync-versioned-client.ts"
  },
  "engines": {
    "node": ">=22.0",
    "npm": ">=9.0"
  },
  "dependencies": {
    "@algorandfoundation/algorand-typescript": "^1.1.0",
    "algosdk": "^3.6.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@algorandfoundation/algokit-client-generator": "^6.0.1",
    "@algorandfoundation/algokit-utils": "^9.2.0",
    "@algorandfoundation/algokit-utils-debug": "^1.0.4",
    "@algorandfoundation/algorand-typescript-testing": "^1.1.0",
    "@algorandfoundation/puya-ts": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "8.1.4",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "0.25.0"
  },
  "packageManager": "pnpm@11.8.0"
}
