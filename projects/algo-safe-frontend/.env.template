# No .env values are required to build or use the frontend.
#
# Built-in defaults:
# - app bootstraps on TestNet
# - MainNet, TestNet, LocalNet, Voi, and Aramid are selectable from the UI
# - LocalNet uses the standard AlgoKit localhost endpoints and KMD defaults
#
# Use this file only if you want to override those defaults.

# Optional: choose the initial wallet network shown on first load.
# VITE_ALGOD_NETWORK=testnet

# Optional: override the selected network's algod endpoint.
# VITE_ALGOD_TOKEN=
# VITE_ALGOD_SERVER=https://testnet-api.algonode.cloud
# VITE_ALGOD_PORT=

# Optional: override the selected network's indexer endpoint.
# VITE_INDEXER_TOKEN=
# VITE_INDEXER_SERVER=https://testnet-idx.algonode.cloud
# VITE_INDEXER_PORT=

# Optional: override LocalNet KMD settings.
# VITE_KMD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
# VITE_KMD_SERVER=http://localhost
# VITE_KMD_PORT=4002
# VITE_KMD_WALLET=unencrypted-default-wallet
# VITE_KMD_PASSWORD=

